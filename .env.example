# ── Database (PostgreSQL) — required for the admin/CMS ──
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/mmitweb"

# ── Auth.js (admin login) ──
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Initial admin account created by `npm run db:seed`
ADMIN_EMAIL=admin@mmit.sa
ADMIN_NAME=مدير الموقع
ADMIN_PASSWORD=change-me-strong-password

# Contact form email delivery (Resend — https://resend.com)
# Without RESEND_API_KEY the contact form still works in dev: submissions are
# logged to the server console instead of emailed.
RESEND_API_KEY=

# Where contact-form submissions are delivered (defaults to admin@mmit.sa)
CONTACT_TO_EMAIL=admin@mmit.sa

# Verified sender address in your Resend account (defaults to onboarding@resend.dev)
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Optional: distributed rate limiting for the contact form via Upstash Redis
# (https://upstash.com). If unset, an in-memory per-instance limiter is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional self-hosted, privacy-friendly analytics — enable ONE.
# Umami (https://umami.is):
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# Plausible (https://plausible.io) — self-hosted or cloud:
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://your-plausible-host/js/script.js
