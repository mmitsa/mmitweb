generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         String   @default("editor") // "admin" | "editor"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Singleton row (id = 1) holding global site settings.
model Settings {
  id           Int      @id @default(1)
  name         String
  tagline      String
  url          String
  email        String
  phone        String
  phoneDisplay String
  whatsapp     String
  address      String
  updatedAt    DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  slug        String   @unique
  icon        String
  title       String
  description String
  overview    String
  features    String[]
  accent      String   @default("secondary") // "secondary" | "primary"
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  icon        String
  title       String
  description String
  tagline     String
  overview    String
  features    String[]
  href        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  client    String
  work      String
  status    String   @default("منتهي") // "قائم" | "منتهي"
  category  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Partner {
  id     String  @id @default(cuid())
  name   String
  sector String
  icon   String
  logo   String?
  order  Int     @default(0)
}

model Faq {
  id       String @id @default(cuid())
  question String
  answer   String
  order    Int    @default(0)
}

model Advantage {
  id          String @id @default(cuid())
  icon        String
  title       String
  description String
  order       Int    @default(0)
}

model Sector {
  id          String @id @default(cuid())
  icon        String
  title       String
  description String
  order       Int    @default(0)
}

model ProcessStep {
  id          String @id @default(cuid())
  icon        String
  title       String
  description String
  order       Int    @default(0)
}

/// Free-form pages built from content blocks (page builder).
model Page {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  published   Boolean  @default(false)
  blocks      Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
